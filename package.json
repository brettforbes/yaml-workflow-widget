{
    "name": "yaml-workflow-widget",
    "version": "0.1.0",
    "title": "YAML Workflow Widget",
    "description": "Iframe widget: YAML workflow code window + Nice-DAG diagram (SPEC-012).",
    "main": "src/js/_index.js",
    "scripts": {
        "build:lang": "npm --prefix packages/workflow-lang ci && npm --prefix packages/workflow-lang run build",
        "start": "npm run build:lang && cross-env NODE_ENV=development webpack serve --progress --live-reload --config webpack.dev.js",
        "build:dev": "npm run build:lang && cross-env NODE_ENV=development webpack --config webpack.dev.js",
        "build": "npm run build:lang && cross-env NODE_ENV=production webpack --config webpack.prod.js",
        "lint": "eslint 'src/**/*.js' || true",
        "prettify": "prettier --write 'src/**/*.js'",
        "watch": "cross-env NODE_ENV=development webpack --config webpack.dev.js --watch"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.24.7",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/preset-env": "^7.24.7",
        "@fontsource/alumni-sans-pinstripe": "^5.0.20",
        "@fontsource/wire-one": "^5.0.19",
        "@fortawesome/fontawesome-free": "^6.5.2",
        "@popperjs/core": "^2.11.8",
        "@vue/compiler-sfc": "^3.5.40",
        "babel-loader": "^9.1.3",
        "bootstrap": "^5.3.8",
        "clean-webpack-plugin": "^4.0.0",
        "concurrently": "^8.2.2",
        "copy-webpack-plugin": "^12.0.2",
        "cross-env": "^7.0.3",
        "css-loader": "^7.1.2",
        "css-minimizer-webpack-plugin": "^7.0.0",
        "d3": "^7.9.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-webpack": "^0.13.8",
        "eslint-plugin-prettier": "^5.1.3",
        "html-webpack-plugin": "^5.6.0",
        "http-server": "^14.1.1",
        "jquery": "^3.7.1",
        "mini-css-extract-plugin": "^2.9.0",
        "postcss": "^8.4.38",
        "postcss-loader": "^8.1.1",
        "postcss-preset-env": "^9.5.14",
        "prettier": "^3.3.1",
        "raw-loader": "^4.0.2",
        "sass": "^1.77.4",
        "sass-loader": "^14.2.1",
        "schema-utils": "^4.2.0",
        "style-loader": "^4.0.0",
        "vue-loader": "^17.4.2",
        "webpack": "^5.92.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.4",
        "webpack-livereload-plugin": "^3.0.2",
        "webpack-merge": "^5.10.0",
        "webpack-merge-and-include-globally": "^2.3.4",
        "webpack-watch-files-plugin": "^1.2.1"
    },
    "dependencies": {
        "dagre": "^0.8.5",
        "html2canvas": "^1.4.1",
        "js-yaml": "^4.3.0",
        "prismjs": "^1.30.0",
        "vue": "^3.5.40",
        "vue-prism-editor": "^2.0.0-alpha.2"
    }
}
