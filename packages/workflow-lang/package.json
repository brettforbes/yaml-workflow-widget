{
  "name": "workflow-lang",
  "version": "0.1.0",
  "private": true,
  "description": "Langium grammar + services for SpiderFeet Workflow + GSE (SPEC-008)",
  "type": "module",
  "scripts": {
    "langium:generate": "langium generate",
    "build": "npm run langium:generate && tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf out src/language/generated",
    "eval:syntax": "npm run build && node evals/syntax.baseline.mjs",
    "smoke:parse": "npm run build && node out/smoke-parse.js",
    "smoke:yaml": "npm run build && node out/smoke-yaml-parse.js",
    "smoke:validate": "npm run build && node out/smoke-validate.js",
    "mcp:smoke": "npm run build && node mcp/smoke.mjs",
    "mcp:start": "npm run build && npx --yes tsx mcp/mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.1",
    "langium": "~4.3.1",
    "langium-ai-tools": "^5.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "langium-cli": "~4.3.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
